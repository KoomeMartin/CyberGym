{
  manifest_version: "0.1.0",
  experimental_features: ["docker"],

  // Configuration schema for the Cybersecurity Agent
  // Currently no additional configuration required
  config_schema: {
    type: "object",
    properties: {
    },
    required: [],
    additionalProperties: false,
  },

  // External services this agent uses
  slots: {
    proxy: { kind: "a2a" },
  },

  // Runtime configuration
  program: {
    // Docker image for the Cybersecurity Agent
    image: "ghcr.io/koomemartin/cybergym:latest",
    entrypoint: "python src/server.py --host 0.0.0.0 --port 9009",

    // Environment variables
    env: {
      PYTHONUNBUFFERED: "1",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 },
      ],
    },
  },

  // Capabilities provided by this agent
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  // Capabilities exposed to the scenario
  exports: { a2a: "a2a" },

  // Agent metadata and configuration
  metadata: {
    description: "Cybersecurity Agent - AI agent for security scanning, threat analysis, and security recommendations",
    version: "1.0.0",
    skills: ["security_scan", "threat_analysis", "security_recommendations"],
    participant_roles: [],
  },
}
